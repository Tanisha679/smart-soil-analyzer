<!DOCTYPE html>
<html>
<head>
    <title>🌱 Smart Soil Analyzer</title>

    <!-- Chart.js CDN -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        body { 
            font-family: Arial; 
            text-align: center; 
            padding: 50px; 
            background: #e8f5e8; 
        }

        .metric { 
            background: white; 
            margin: 20px; 
            padding: 20px; 
            border-radius: 10px; 
            box-shadow: 0 4px 8px rgba(0,0,0,0.1); 
        }

        h1 { color: #2d5a2d; }

        canvas {
            max-width: 300px;
            margin: auto;
        }

        select {
            padding: 10px;
            font-size: 16px;
            border-radius: 8px;
        }
    </style>
</head>

<body>

    <h1>🌱 Smart Soil Analyzer</h1>
    <p>✅ Made by Tanisha</p>

    <!-- REGION SELECTOR -->
    <div class="metric">
        <h2>📍 Select Region</h2>
        <select id="regionSelect" onchange="updateRegion()">
            <option value="">-- Choose Region --</option>
            <option value="North India">North India</option>
            <option value="South India">South India</option>
            <option value="West India">West India</option>
            <option value="East India">East India</option>
        </select>

        <h3 id="regionDisplay">No region selected</h3>
    </div>

    <!-- Moisture -->
    <div class="metric">
        <h2>💧 Moisture Level</h2>
        <h1>65%</h1>
        <canvas id="moistureChart"></canvas>
    </div>

    <!-- pH -->
    <div class="metric">
        <h2>🧪 Soil pH Level</h2>  
        <h1>6.8</h1>
        <canvas id="phChart"></canvas>
    </div>

    <!-- Temperature -->
    <div class="metric">
        <h2>🌡️ Temperature</h2>
        <h1>25.5°C</h1>
        <canvas id="tempChart"></canvas>
    </div>

    <p>
        <a href="https://github.com/Tanisha679/smart-soil-analyzer">
            View Code on GitHub
        </a>
    </p>

    <script>
        function updateRegion() {
            let region = document.getElementById("regionSelect").value;
            let display = document.getElementById("regionDisplay");

            if(region === "") {
                display.innerText = "No region selected";
            } else {
                display.innerText = "Selected Region: " + region;
            }
        }

        // Moisture Chart
        new Chart(document.getElementById("moistureChart"), {
            type: 'line',
            data: {
                labels: ["Mon", "Tue", "Wed", "Thu", "Fri"],
                datasets: [{
                    label: "Moisture %",
                    data: [60, 62, 64, 65, 65],
                    borderColor: "blue",
                    fill: false
                }]
            }
        });

        // pH Chart
        new Chart(document.getElementById("phChart"), {
            type: 'line',
            data: {
                labels: ["Mon", "Tue", "Wed", "Thu", "Fri"],
                datasets: [{
                    label: "pH Level",
                    data: [6.5, 6.6, 6.7, 6.8, 6.8],
                    borderColor: "green",
                    fill: false
                }]
            }
        });

        // Temperature Chart
        new Chart(document.getElementById("tempChart"), {
            type: 'line',
            data: {
                labels: ["Mon", "Tue", "Wed", "Thu", "Fri"],
                datasets: [{
                    label: "Temperature °C",
                    data: [24, 25, 25.5, 26, 25.5],
                    borderColor: "red",
                    fill: false
                }]
            }
        });
    </script>

</body>
</html>
